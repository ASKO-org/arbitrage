# Copy this file to .env and fill in real values. .env is gitignored — never
# commit real keys.

# Binance/Bybit API keys and secrets are NOT set here — they're no longer
# stored in plaintext at all. Instead they live AES-256-GCM encrypted at
# SECRETS_FILE_PATH, decrypted at startup using the master key at
# SECRETS_MASTER_KEY_PATH (kept outside this repo entirely). See
# common/security/SecretsStore.h for the design, and set them up with:
#
#   ./build/secrets_cli init ~/.secrets/instrument_loader.key
#   ./build/secrets_cli set ~/.secrets/instrument_loader.key secrets/exchange_keys.enc.json binance_api_key
#   ./build/secrets_cli set ~/.secrets/instrument_loader.key secrets/exchange_keys.enc.json binance_api_secret
#   ./build/secrets_cli set ~/.secrets/instrument_loader.key secrets/exchange_keys.enc.json bybit_api_key
#   ./build/secrets_cli set ~/.secrets/instrument_loader.key secrets/exchange_keys.enc.json bybit_api_secret
#
# Both env vars below are just paths, not secrets — only override if you
# want a non-default location.
# SECRETS_MASTER_KEY_PATH=~/.secrets/instrument_loader.key
# SECRETS_FILE_PATH=secrets/exchange_keys.enc.json

# Binance testnet: https://testnet.binance.vision — log in with GitHub,
# generate an HMAC API key, use it with secrets_cli above.
BINANCE_BASE_URL=https://testnet.binance.vision

# Bybit testnet: https://testnet.bybit.com — register a separate testnet
# account, then create an API key with trading permission under API
# Management, and use it with secrets_cli above.
BYBIT_BASE_URL=https://api-testnet.bybit.com

# Only override these if Postgres/Redis aren't the local defaults.
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=instruments
# PGUSER=postgres
# PGPASSWORD=postgres
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Account-wide net-position limit per venue+symbol that OrderRouter enforces
# across every strategy sharing this account.
# EXECUTION_MAX_ABS_POSITION=1000
